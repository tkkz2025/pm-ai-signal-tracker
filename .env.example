# PM AI Signal Tracker — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Required: Gemini API key from Google AI Studio
GEMINI_API_KEY=your-gemini-api-key-here

# Required: Search API key (SerpApi or equivalent)
SEARCH_API_KEY=your-search-api-key-here

# Optional: Set to FALSE to use AI Studio instead of Vertex AI
GOOGLE_GENAI_USE_ENTERPRISE=FALSE

# Optional: GCP project (required for Agent Runtime deployment)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional: GCP region for deployment
GOOGLE_CLOUD_LOCATION=asia-northeast1
